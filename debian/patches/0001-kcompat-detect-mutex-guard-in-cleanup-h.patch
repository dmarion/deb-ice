From: Damjan Marion <dmarion@me.com>
Subject: kcompat: detect existing mutex guards

Linux 7.0 defines the mutex guard using DEFINE_LOCK_GUARD_1(mutex, ...)
instead of DEFINE_GUARD(mutex, ...). Treat either guard form as present
before deciding that the backport needs to define the mutex guard.

--- a/src/kcompat-generator.sh
+++ b/src/kcompat-generator.sh
@@ -83,7 +83,12 @@ function gen-cleanup() {
 	rcuh='include/linux/rcupdate.h'
 	gen NEED_DEFINE_FREE if macro DEFINE_FREE absent in "$ch"
 	gen NEED___DEFINE_CLASS_IS_CONDITIONAL if macro __DEFINE_CLASS_IS_CONDITIONAL absent in "$ch"
-	gen NEED_DEFINE_GUARD_MUTEX if invocation of macro DEFINE_GUARD absent or lacks mutex_lock in "$mh"
+	MUTEX_GUARD=0
+	if check invocation of macro DEFINE_GUARD matches mutex_lock in "$mh" "$ch" ||
+	   check invocation of macro DEFINE_LOCK_GUARD_1 matches mutex_lock in "$mh" "$ch"; then
+		MUTEX_GUARD=1
+	fi
+	gen NEED_DEFINE_GUARD_MUTEX if string "$MUTEX_GUARD" equals 0
 	gen NEED_LOCK_GUARD_FOR_RCU if invocation of macro DEFINE_LOCK_GUARD_0 absent or lacks rcu in "$rcuh"
 	gen NEED_DEFINE_FREE_KFREE if invocation of macro DEFINE_FREE absent or lacks kfree in "$slabh"
 	gen NEED_DEFINE_FREE_KVFREE if invocation of macro DEFINE_FREE absent or lacks kvfree in "$slabh"
